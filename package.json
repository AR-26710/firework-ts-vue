{
  "name": "firework",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,css,scss,md}\"",
    "generate-icons": "node scripts/extract-icons.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/mdi": "^1.2.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4"
  }
}
